{
  "name": "Web Search Connector",
  "description": "Search the web via multiple providers and return structured results",
  "type": "connector",
  "complexity": "beginner",
  "features": [
    "Multi-provider web search",
    "Structured result format",
    "Rate limiting",
    "Result caching",
    "Safe search filtering"
  ],
  "env_vars": [
    "AGENT_NAME",
    "AGENT_ID",
    "PLATFORM_URL",
    "PORT",
    "SEARCH_API_KEY",
    "SEARCH_PROVIDER"
  ],
  "icon": "🔍",
  "connector": {
    "service_name": "web-search",
    "auth_type": "api_key",
    "capabilities": [
      "search"
    ]
  },
  "methods": [
    {
      "name": "search",
      "description": "Search the web and return results",
      "params": {
        "query": {
          "type": "string",
          "required": true,
          "description": "Search query"
        }
      },
      "returns": {
        "results": {
          "type": "array",
          "description": "Array of { title, url, snippet }"
        }
      },
      "example": {
        "request": {
          "jsonrpc": "2.0",
          "id": 1,
          "method": "search",
          "params": {
            "query": "AI agents"
          }
        },
        "response": {
          "jsonrpc": "2.0",
          "id": 1,
          "result": {
            "results": [
              {
                "title": "AI Agents Guide",
                "url": "https://example.com",
                "snippet": "..."
              }
            ]
          }
        }
      }
    }
  ],
  "api": [
    {
      "method": "GET",
      "path": "/health",
      "description": "Health check"
    },
    {
      "method": "GET",
      "path": "/.well-known/agent-card.json",
      "description": "Agent discovery card"
    },
    {
      "method": "GET",
      "path": "/docs",
      "description": "API documentation (HTML)"
    },
    {
      "method": "POST",
      "path": "/api/a2a",
      "description": "A2A JSON-RPC 2.0 endpoint"
    }
  ],
  "metadata": {
    "author": "agenxia",
    "source_template": "template-web-search",
    "type": "connector"
  }
}